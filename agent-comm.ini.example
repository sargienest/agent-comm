[runtime]
# Set this before `start`. Leave it blank in the template.
working_dir =
language = en
codex_home = ~/.codex
dangerously_bypass_approvals_and_sandbox = false

[tmux]
# blank = auto-generated from repo path
session_name =

[ui]
auto_start = true
port = 43861
open_browser = true
language =

[roles]
extra_paths =

[notification]
command_received = false
research_completed = false
implementation_task_created = false
implementer_started = false
tester_started = false
review_started = false
review_approved = false
review_requested_changes = false
workflow_completed = false
question_opened = false

[discord]
enable = false
# This is the env var name to resolve from the shell or `.env`, not the webhook URL itself.
webhook_url = DISCORD_WEBHOOK_URL
